# =============================================================================
# CancerQR Environment Variables
# Copy this file to .env and fill in your values:  cp env.example .env
# =============================================================================

# --- Database (PostgreSQL) ---
DB_NAME=oncologydb
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_strong_password_here

# --- AWS S3 (medical report storage) ---
STORAGE_TYPE=s3
S3_BUCKET_NAME=your-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY=your-access-key
AWS_SECRET_KEY=your-secret-key

# --- Security ---
ENCRYPTION_KEY=CHANGE_ME_random_32_char_string
JWT_SECRET=CHANGE_ME_random_64_char_string

# --- WhatsApp Business API (optional, leave empty to skip) ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# --- AI Verification (optional) ---
AI_VERIFICATION_ENABLED=false
ANTHROPIC_API_KEY=
