# =============================================================================
# CancerQR Environment Variables
# Copy this file to .env and fill in your values:  cp env.example .env
# =============================================================================

# --- Database (PostgreSQL) ---
DB_NAME=oncologydb
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_strong_password_here

# --- AWS S3 (medical report storage) ---
# Files are written to S3 with AES256 server-side encryption (set in code).
#
# Credentials: prefer attaching an IAM instance role to the EC2 host and
# leaving AWS_ACCESS_KEY / AWS_SECRET_KEY blank. The AWS SDK falls back to
# the EC2 metadata service automatically. Static keys are only needed for
# local dev or non-EC2 hosts.
STORAGE_TYPE=s3
S3_BUCKET_NAME=your-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# --- PHI column encryption + HMAC lookup ---
# Two independent AES-256 keys (base64-encoded 32 bytes each). Generate each
# SEPARATELY with: openssl rand -base64 32
# Both REQUIRED in production; app fails to start without them.
# NEVER commit real values to git. NEVER use the same value for both.
#
# PHI_ENCRYPTION_KEY:
#   AES-GCM encryption of patient.name, doctor.fullName/email/phone, and
#   patient.whatsappNumber. Loss = permanent loss of every encrypted PHI value.
#   Registered as v1 internally (back-compat name).
#
# For key rotation (PR 12): add PHI_ENCRYPTION_KEY_V2 alongside PHI_ENCRYPTION_KEY
# to introduce a v2 key. Highest configured version is used for new writes; both
# keys are kept available for reads of legacy {enc:v1} rows. After running the
# admin /admin/phi/rotate sweep to drift all rows to v2, remove the v1 value.
# Same pattern applies for v3, v4, etc. Generate each with: openssl rand -base64 32
# Never reuse a value across versions.
#
# PHI_HMAC_KEY:
#   HMAC-SHA256 of patient.whatsapp_number_hash for equality lookups on every
#   inbound webhook. Loss is recoverable but requires a one-shot sweep to
#   re-hash every row's decrypted number under the new key.
#
# Back both up alongside your other production secrets (password manager today,
# AWS Secrets Manager eventually).
PHI_ENCRYPTION_KEY=
PHI_HMAC_KEY=

# --- WhatsApp Business API ---
# Leave WHATSAPP_WEBHOOK_SECRET empty in dev to skip signature verification.
# In production, set it to your Meta App Secret (Settings → Basic → App Secret).
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_SECRET=

# --- AI Verification (optional) ---
AI_VERIFICATION_ENABLED=false
ANTHROPIC_API_KEY=
